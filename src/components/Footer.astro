---
const currentYear = new Date().getFullYear();
---
<footer class="bg-secondary text-surface pt-16 pb-8" role="contentinfo">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Column 1 -->
      <div class="space-y-4">
        <a href="/" class="block mb-4 focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded">
          <span class="text-xl font-bold text-white">BDA Baudesign Akustik GmbH</span>
        </a>
        <p class="text-gray-400 text-sm leading-relaxed">
          Zertifizierter Fachbetrieb für Akustik, Fassaden, WDVS und Innenausbau. Ihr zuverlässiger Partner von der Planung bis zur Ausführung.
        </p>
      </div>
      
      <!-- Column 2 -->
      <div>
        <h3 class="text-lg font-semibold mb-6 border-b border-gray-700 pb-2">Kontakt</h3>
        <address class="not-italic">
          <ul class="space-y-3 text-gray-400 text-sm">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-primary mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              <span>Bochumer Straße 207<br/>45661 Recklinghausen</span>
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              <a href="tel:023619994017" class="hover:text-primary transition-colors focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded">02361 9994017</a>
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
              <a href="tel:01724193175" class="hover:text-primary transition-colors focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded">0172 4193175 (Mobil)</a>
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              <a href="mailto:baudesign.akustik@web.de" class="hover:text-primary transition-colors focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded">baudesign.akustik@web.de</a>
            </li>
          </ul>
        </address>
      </div>

      <!-- Column 3 -->
      <nav aria-label="Leistungen">
        <h3 class="text-lg font-semibold mb-6 border-b border-gray-700 pb-2">Leistungen</h3>
        <ul class="space-y-2 text-gray-400 text-sm">
          <li><a href="/leistungen#akustik" class="hover:text-primary transition-colors focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded">Akustikbau</a></li>
          <li><a href="/leistungen#fassaden" class="hover:text-primary transition-colors focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded">Fassadenarbeiten</a></li>
          <li><a href="/leistungen#malerarbeiten" class="hover:text-primary transition-colors focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded">Malerarbeiten</a></li>
          <li><a href="/leistungen#wdvs" class="hover:text-primary transition-colors focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded">WDVS</a></li>
          <li><a href="/leistungen#abbruch" class="hover:text-primary transition-colors focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded">Abbrucharbeiten</a></li>
          <li><a href="/leistungen#galabau" class="hover:text-primary transition-colors focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded">Galabau & Fliesen</a></li>
        </ul>
      </nav>

      <!-- Column 4 -->
      <nav aria-label="Rechtliches">
        <h3 class="text-lg font-semibold mb-6 border-b border-gray-700 pb-2">Rechtliches</h3>
        <ul class="space-y-2 text-gray-400 text-sm">
          <li><a href="/impressum" class="hover:text-primary transition-colors focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded">Impressum</a></li>
          <li><a href="/datenschutz" class="hover:text-primary transition-colors focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded">Datenschutz</a></li>
        </ul>
      </nav>
    </div>
    
    <div class="mt-12 pt-8 border-t border-gray-800 text-center text-gray-500 text-sm">
      <p>&copy; {currentYear} BDA Baudesign Akustik GmbH. Alle Rechte vorbehalten.</p>
    </div>
  </div>
</footer>
