---
const currentPath = Astro.url.pathname;
---
<header class="sticky top-0 z-50 w-full bg-white shadow-sm border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-24 md:h-28">
      
      <!-- Links: Leer für Balance -->
      <div class="flex-1"></div>

      <!-- Logo mittig, so groß wie möglich -->
      <div class="flex-shrink-0 flex items-center justify-center">
        <a href="/" class="flex items-center focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded-lg transition-transform hover:scale-105" aria-label="Zur Startseite">
          <img src="/images/logo.png" alt="BDA Baudesign Akustik GmbH Logo" class="h-auto max-h-20 md:max-h-24 w-auto drop-shadow-sm" width="200" height="80" />
        </a>
      </div>

      <!-- Rechts: Burger Menu Button (44x44px touch target) -->
      <div class="flex-1 flex justify-end items-center">
        <button 
          id="mobile-menu-btn" 
          class="text-secondary hover:text-primary focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 p-3 rounded-lg transition-colors min-w-[44px] min-h-[44px] flex items-center justify-center" 
          aria-label="Menü öffnen" 
          aria-expanded="false" 
          aria-controls="mobile-menu"
          type="button"
        >
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu (wird von allen Bildschirmgrößen genutzt) -->
  <div 
    id="mobile-menu" 
    class="hidden bg-surface border-t border-gray-100 shadow-xl absolute w-full left-0"
    role="navigation"
    aria-label="Hauptnavigation"
  >
    <nav class="px-4 py-6 space-y-4">
      <a 
        href="/" 
        class={`block text-lg font-medium transition-colors ${currentPath === '/' ? 'text-primary' : 'text-secondary hover:text-primary'}`}
        aria-current={currentPath === '/' ? 'page' : undefined}
      >
        Startseite
      </a>
      <a 
        href="/leistungen" 
        class={`block text-lg font-medium transition-colors ${currentPath === '/leistungen' ? 'text-primary' : 'text-secondary hover:text-primary'}`}
        aria-current={currentPath === '/leistungen' ? 'page' : undefined}
      >
        Leistungen
      </a>
      <a 
        href="/ueber-uns" 
        class={`block text-lg font-medium transition-colors ${currentPath === '/ueber-uns' ? 'text-primary' : 'text-secondary hover:text-primary'}`}
        aria-current={currentPath === '/ueber-uns' ? 'page' : undefined}
      >
        Über Uns
      </a>
      <a 
        href="/referenzen" 
        class={`block text-lg font-medium transition-colors ${currentPath === '/referenzen' ? 'text-primary' : 'text-secondary hover:text-primary'}`}
        aria-current={currentPath === '/referenzen' ? 'page' : undefined}
      >
        Referenzen
      </a>
      <a 
        href="/kontakt" 
        class={`block text-lg font-medium transition-colors ${currentPath === '/kontakt' ? 'text-primary' : 'text-secondary hover:text-primary'}`}
        aria-current={currentPath === '/kontakt' ? 'page' : undefined}
      >
        Kontakt
      </a>
      <div class="pt-4 border-t border-gray-100 space-y-3">
        <a href="tel:023619994017" class="flex items-center gap-2 text-secondary hover:text-primary font-medium min-h-[44px]">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20 15.5c-1.2 0-2.4-.2-3.6-.6-.3-.1-.7 0-1 .2l-2.2 2.2c-2.8-1.4-5.1-3.8-6.6-6.6l2.2-2.2c.3-.3.4-.7.2-1-.4-1.2-.6-2.4-.6-3.6 0-.6-.4-1-1-1H4.4C3.8 3.5 3 4 3 5c0 9.4 7.6 17 17 17 1 0 1.5-.8 1.5-1.4v-4.1c0-.6-.4-1-1-1V15.5z"/></svg>
          02361 9994017
        </a>
        <a href="tel:01724193175" class="flex items-center gap-2 text-secondary hover:text-primary font-medium min-h-[44px]">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
          0172 4193175 (Mobil)
        </a>
        <a href="/kontakt" class="block w-full text-center bg-primary text-surface py-3 rounded-md font-bold shadow-lg hover:bg-accent transition-colors min-h-[44px] flex items-center justify-center">
          Jetzt anfragen
        </a>
      </div>
    </nav>
  </div>
</header>
<script>
  (function() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    
    if(btn && menu) {
      btn.addEventListener('click', () => {
        const isHidden = menu.classList.contains('hidden');
        menu.classList.toggle('hidden');
        btn.setAttribute('aria-expanded', String(isHidden));
      });
      
      // Close menu on escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !menu.classList.contains('hidden')) {
          menu.classList.add('hidden');
          btn.setAttribute('aria-expanded', 'false');
          btn.focus();
        }
      });
    }
  })();
</script>
