---
import Layout from '../layouts/Layout.astro';

const WEB3FORMS_ACCESS_KEY = "37e82d64-cdce-4088-bfcb-4d94297ed9c0";
---

<Layout 
  title="Kontakt - BDA Baudesign Akustik GmbH" 
  description="Nehmen Sie Kontakt zu uns auf. Wir beraten Sie gerne zu Ihrem Bauprojekt in und um Recklinghausen."
>
  <!-- Sektion 1: Seiten-Hero -->
  <section class="h-64 md:h-80 bg-secondary flex items-center justify-center relative overflow-hidden text-surface" aria-labelledby="hero-heading">
    <div class="absolute inset-0 bg-gray-900 opacity-50" aria-hidden="true"></div>
    <div class="relative z-10 text-center px-4">
      <h1 id="hero-heading" class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4 drop-shadow-lg">Kontaktieren Sie uns</h1>
      <p class="text-lg md:text-xl text-gray-200 max-w-2xl mx-auto">Lassen Sie uns gemeinsam über Ihr nächstes Bauvorhaben sprechen.</p>
    </div>
  </section>

  <!-- Sektion 2: Split-Layout (50/50) -->
  <div class="bg-background py-16 md:py-24 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-1/2 h-full bg-surface hidden lg:block rounded-l-[100px] border-l border-gray-100 shadow-2xl" aria-hidden="true"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        
        <!-- Linke Seite (Infos) -->
        <div>
          <h2 class="text-4xl md:text-5xl font-extrabold text-secondary mb-6 leading-tight">Wir sind für Sie da.</h2>
          <p class="text-lg text-gray-600 mb-10 leading-relaxed">Persönliche Beratung und direkte Erreichbarkeit sind das Fundament unserer Arbeit. Rufen Sie uns an oder statten Sie uns einen Besuch ab.</p>
          
          <div class="space-y-8">
            <a href="tel:023619994017" class="flex items-start gap-5 p-6 bg-surface rounded-2xl shadow-sm border border-gray-100 hover:border-primary/50 transition-colors group min-h-[44px]">
              <div class="bg-primary/10 p-4 rounded-xl group-hover:bg-primary transition-colors flex-shrink-0" aria-hidden="true">
                <svg class="w-6 h-6 text-primary group-hover:text-surface" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              </div>
              <div class="mt-2">
                <h3 class="font-bold text-secondary text-xl mb-1 group-hover:text-primary transition-colors">Telefon</h3>
                <span class="text-gray-500 font-medium text-lg block">02361 9994017</span>
                <span class="text-gray-400 text-sm">Festnetz</span>
              </div>
            </a>
            
            <a href="tel:01724193175" class="flex items-start gap-5 p-6 bg-surface rounded-2xl shadow-sm border border-gray-100 hover:border-primary/50 transition-colors group min-h-[44px]">
              <div class="bg-primary/10 p-4 rounded-xl group-hover:bg-primary transition-colors flex-shrink-0" aria-hidden="true">
                <svg class="w-6 h-6 text-primary group-hover:text-surface" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
              </div>
              <div class="mt-2">
                <h3 class="font-bold text-secondary text-xl mb-1 group-hover:text-primary transition-colors">Mobil</h3>
                <span class="text-gray-500 font-medium text-lg">0172 4193175</span>
              </div>
            </a>
            
            <a href="mailto:baudesign.akustik@web.de" class="flex items-start gap-5 p-6 bg-surface rounded-2xl shadow-sm border border-gray-100 hover:border-primary/50 transition-colors group min-h-[44px]">
              <div class="bg-primary/10 p-4 rounded-xl group-hover:bg-primary transition-colors flex-shrink-0" aria-hidden="true">
                <svg class="w-6 h-6 text-primary group-hover:text-surface" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </div>
              <div class="mt-2 text-left">
                <h3 class="font-bold text-secondary text-xl mb-1 group-hover:text-primary transition-colors">E-Mail</h3>
                <span class="text-gray-500 font-medium text-lg break-all">baudesign.akustik@web.de</span>
              </div>
            </a>

            <div class="flex items-start gap-5 p-6 bg-surface rounded-2xl shadow-sm border border-gray-100">
              <div class="bg-primary/10 p-4 rounded-xl flex-shrink-0" aria-hidden="true">
                <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              </div>
              <div class="mt-2 text-left">
                <h3 class="font-bold text-secondary text-xl mb-1">Standort</h3>
                <span class="text-gray-500 font-medium text-lg block">Bochumer Straße 207</span>
                <span class="text-gray-500 font-medium text-lg">45661 Recklinghausen</span>
              </div>
            </div>

            <!-- Google Maps -->
            <div class="w-full aspect-[21/9] bg-gray-200 border border-gray-300 rounded-2xl flex items-center justify-center relative overflow-hidden shadow-inner mt-8">
              <iframe 
                title="Standort BDA Baudesign Akustik GmbH auf Google Maps"
                width="100%" 
                height="100%" 
                class="absolute inset-0 border-0" 
                loading="lazy" 
                allowfullscreen 
                referrerpolicy="no-referrer-when-downgrade" 
                src="https://maps.google.com/maps?q=Bochumer%20Stra%C3%9Fe%20207,%2045661%20Recklinghausen&t=&z=15&ie=UTF8&iwloc=&output=embed"
              ></iframe>
            </div>
          </div>
        </div>

        <!-- Rechte Seite (Formular) -->
        <div class="bg-surface rounded-3xl p-8 lg:p-12 shadow-2xl border border-gray-100/50">
          <form action="https://api.web3forms.com/submit" method="POST" id="contact-form" class="space-y-6" novalidate>
            <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
            <input type="checkbox" name="botcheck" class="hidden" style="display: none;" tabindex="-1" aria-hidden="true" />
            <input type="hidden" name="subject" value="Neue Kontaktanfrage BDA Baudesign Akustik" />
            <input type="hidden" name="redirect" value="https://web3forms.com/success" />
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-bold text-secondary mb-2">
                  Vollständiger Name <span class="text-primary" aria-label="Pflichtfeld">*</span>
                </label>
                <input 
                  type="text" 
                  id="name" 
                  name="name" 
                  required 
                  autocomplete="name"
                  aria-required="true"
                  aria-describedby="name-error"
                  class="w-full bg-background border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors text-secondary placeholder-gray-400 min-h-[44px]" 
                  placeholder="Max Mustermann"
                >
                <span id="name-error" class="text-red-500 text-sm mt-1 hidden" role="alert"></span>
              </div>
              <div>
                <label for="email" class="block text-sm font-bold text-secondary mb-2">
                  E-Mail Adresse <span class="text-primary" aria-label="Pflichtfeld">*</span>
                </label>
                <input 
                  type="email" 
                  id="email" 
                  name="email" 
                  required 
                  autocomplete="email"
                  aria-required="true"
                  aria-describedby="email-error"
                  class="w-full bg-background border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors text-secondary placeholder-gray-400 min-h-[44px]" 
                  placeholder="max@beispiel.de"
                >
                <span id="email-error" class="text-red-500 text-sm mt-1 hidden" role="alert"></span>
              </div>
            </div>

            <div>
              <label for="phone" class="block text-sm font-bold text-secondary mb-2">Telefonnummer</label>
              <input 
                type="tel" 
                id="phone" 
                name="phone" 
                autocomplete="tel"
                aria-describedby="phone-hint"
                class="w-full bg-background border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors text-secondary placeholder-gray-400 min-h-[44px]" 
                placeholder="0123 456789"
              >
              <span id="phone-hint" class="text-gray-400 text-xs mt-1">Optional, aber hilfreich für schnelle Rückfragen</span>
            </div>

            <div>
              <label for="message" class="block text-sm font-bold text-secondary mb-2">
                Ihre Nachricht <span class="text-primary" aria-label="Pflichtfeld">*</span>
              </label>
              <textarea 
                id="message" 
                name="message" 
                rows="5" 
                required
                aria-required="true"
                aria-describedby="message-error"
                class="w-full bg-background border border-gray-200 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-colors text-secondary placeholder-gray-400 resize-y min-h-[120px]" 
                placeholder="Beschreiben Sie kurz Ihr geplantes Bauvorhaben..."
              ></textarea>
              <span id="message-error" class="text-red-500 text-sm mt-1 hidden" role="alert"></span>
            </div>

            <div class="flex items-start">
               <input 
                 id="dsgvo" 
                 type="checkbox" 
                 required 
                 aria-required="true"
                 aria-describedby="dsgvo-error"
                 class="mt-1 mr-3 w-5 h-5 rounded text-primary border-gray-300 focus:ring-2 focus:ring-primary focus:ring-offset-2 cursor-pointer min-w-[20px] min-h-[20px]"
               >
               <label for="dsgvo" class="text-sm text-gray-500 leading-relaxed cursor-pointer">
                 Ich habe die <a href="/datenschutz" class="text-primary hover:underline font-medium focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded">Datenschutzerklärung</a> zur Kenntnis genommen und stimme der Verarbeitung meiner Daten zu. <span class="text-primary" aria-label="Pflichtfeld">*</span>
               </label>
            </div>
            <span id="dsgvo-error" class="text-red-500 text-sm hidden" role="alert"></span>

            <button 
              type="submit" 
              class="w-full bg-primary hover:bg-accent focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 text-surface py-4 rounded-xl font-bold text-lg transition-all shadow-lg hover:shadow-primary/30 hover:-translate-y-1 min-h-[56px]"
            >
              Nachricht senden
            </button>
            <p 
              id="result-message" 
              class="text-sm text-center font-medium mt-4 hidden"
              role="status"
              aria-live="polite"
              aria-atomic="true"
            ></p>
          </form>
        </div>

      </div>
    </div>
  </div>
</Layout>

<script>
  (function() {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const result = document.getElementById('result-message');
    
    if (form && result) {
      // Real-time validation
      const inputs = form.querySelectorAll('input[required], textarea[required]');
      inputs.forEach(input => {
        input.addEventListener('blur', () => {
          validateField(input as HTMLInputElement | HTMLTextAreaElement);
        });
      });
      
      function validateField(field: HTMLInputElement | HTMLTextAreaElement): boolean {
        const errorId = field.getAttribute('aria-describedby')?.split(' ')[0];
        const errorEl = errorId ? document.getElementById(errorId) : null;
        
        if (!field.validity.valid) {
          if (errorEl) {
            errorEl.classList.remove('hidden');
            if (field.validity.valueMissing) {
              errorEl.textContent = 'Dieses Feld ist erforderlich.';
            } else if (field.validity.typeMismatch && field.type === 'email') {
              errorEl.textContent = 'Bitte geben Sie eine gültige E-Mail-Adresse ein.';
            }
          }
          field.setAttribute('aria-invalid', 'true');
          return false;
        } else {
          if (errorEl) errorEl.classList.add('hidden');
          field.setAttribute('aria-invalid', 'false');
          return true;
        }
      }
    
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        
        // Validate all fields
        let isValid = true;
        inputs.forEach(input => {
          if (!validateField(input as HTMLInputElement | HTMLTextAreaElement)) {
            isValid = false;
          }
        });
        
        if (!isValid) {
          result.classList.remove('hidden', 'text-green-500');
          result.classList.add('text-red-500');
          result.innerHTML = 'Bitte korrigieren Sie die markierten Felder.';
          return;
        }
        
        const formData = new FormData(form);
        const object = Object.fromEntries(formData);
        const json = JSON.stringify(object);

        result.classList.remove('hidden', 'text-red-500', 'text-green-500');
        result.classList.add('text-secondary');
        result.innerHTML = "Bitte warten...";

        fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: json
        })
        .then(async (response) => {
          let json = await response.json();
          if (response.status == 200) {
            result.innerHTML = "✓ Erfolgreich versendet! Wir melden uns in Kürze.";
            result.classList.remove('text-secondary');
            result.classList.add('text-green-600');
            form.reset();
          } else {
            console.log(response);
            result.innerHTML = json.message || "Etwas ist schiefgelaufen! Bitte versuchen Sie es später erneut.";
            result.classList.remove('text-secondary');
            result.classList.add('text-red-500');
          }
        })
        .catch(error => {
          console.log(error);
          result.innerHTML = "Fehler beim Senden. Bitte versuchen Sie es erneut oder rufen Sie uns an.";
          result.classList.remove('text-secondary');
          result.classList.add('text-red-500');
        });
      });
    }
  })();
</script>
