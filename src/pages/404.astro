---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Seite nicht gefunden" 
  description="Die angeforderte Seite konnte nicht gefunden werden."
>
  <section class="min-h-[70vh] flex items-center justify-center bg-background" aria-labelledby="error-heading">
    <div class="text-center px-4 max-w-2xl mx-auto">
      <div class="mb-8">
        <span class="text-8xl md:text-9xl font-black text-primary/20" aria-hidden="true">404</span>
      </div>
      <h1 id="error-heading" class="text-3xl md:text-4xl font-bold text-secondary mb-6">Seite nicht gefunden</h1>
      <p class="text-gray-600 mb-8 text-lg leading-relaxed">
        Die von Ihnen gesuchte Seite existiert leider nicht oder wurde verschoben. 
        Möglicherweise haben Sie eine falsche Adresse eingegeben oder der Link ist veraltet.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 bg-primary hover:bg-accent focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 text-surface px-8 py-4 rounded-md font-bold transition-colors min-h-[56px]"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          Zurück zur Startseite
        </a>
        <a 
          href="/kontakt" 
          class="inline-flex items-center gap-2 text-primary hover:text-accent font-bold transition-colors min-h-[44px] px-4"
        >
          Kontakt aufnehmen
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
      
      <!-- Nützliche Links -->
      <nav class="mt-12 pt-8 border-t border-gray-200" aria-label="Nützliche Links">
        <h2 class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-4">Beliebte Seiten</h2>
        <ul class="flex flex-wrap justify-center gap-4 text-sm">
          <li><a href="/leistungen" class="text-gray-600 hover:text-primary transition-colors focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded">Unsere Leistungen</a></li>
          <li><a href="/ueber-uns" class="text-gray-600 hover:text-primary transition-colors focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded">Über uns</a></li>
          <li><a href="/referenzen" class="text-gray-600 hover:text-primary transition-colors focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded">Referenzen</a></li>
          <li><a href="/kontakt" class="text-gray-600 hover:text-primary transition-colors focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded">Kontakt</a></li>
        </ul>
      </nav>
    </div>
  </section>
</Layout>
