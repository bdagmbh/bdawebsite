---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
	title: string;
	description: string;
	image?: string;
}

const { title, description, image = '/images/logo.png' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://bda-baudesign-akustik.de');
---

<!doctype html>
<html lang="de">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="theme-color" content="#D32F2F" />
		<link rel="icon" type="image/png" href="/images/logo.png" />
		<link rel="manifest" href="/manifest.json" />
		<link rel="canonical" href={canonicalURL} />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | BDA Baudesign Akustik GmbH</title>
		
		<!-- Preconnect to external domains -->
		<link rel="preconnect" href="https://api.web3forms.com" />
		<link rel="preconnect" href="https://maps.google.com" />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={`${title} | BDA Baudesign Akustik GmbH`} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.site || 'https://bda-baudesign-akustik.de')} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:locale" content="de_DE" />
		<meta property="og:site_name" content="BDA Baudesign Akustik GmbH" />
		
		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonicalURL} />
		<meta name="twitter:title" content={`${title} | BDA Baudesign Akustik GmbH`} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={new URL(image, Astro.site || 'https://bda-baudesign-akustik.de')} />
	</head>
	<body class="flex flex-col min-h-screen">
		<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-primary text-white px-4 py-2 rounded-md z-[200] font-bold">
			Zum Hauptinhalt springen
		</a>
		<Navbar />
		<main class="flex-grow" id="main-content">
			<slot />
		</main>
		<Footer />
		<CookieBanner />
	</body>
</html>
